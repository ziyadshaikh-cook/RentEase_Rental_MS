<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RentEase — Users</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-wrapper">
    <%- include('../partials/sidebar-admin') %>

    <div class="main-content">
        <div class="topbar">
            <div class="topbar-title">Users</div>
            <div class="topbar-user"><%= user.name %></div>
        </div>

        <div class="page-content">

            <div class="page-actions">
                <button class="btn-primary-custom btn-inline" onclick="document.getElementById('addUserModal').style.display='flex'">
                    + Add User
                </button>
            </div>

            <!-- Property Managers -->
            <div class="card">
                <div class="card-header">
                    <h3>Property Managers</h3>
                    <span class="badge badge-green"><%= managers.length %> Active</span>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Assigned Property</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% managers.forEach(function(manager, index) { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= manager.name %></td>
                            <td><%= manager.email %></td>
                            <td><%= manager.phone || '—' %></td>
                            <td><%= manager.property_name || 'Unassigned' %></td>
                            <td>
                                <span class="badge <%= manager.is_active ? 'badge-green' : 'badge-orange' %>">
                                    <%= manager.is_active ? 'Active' : 'Inactive' %>
                                </span>
                            </td>
                            <td>
                                <a href="#" class="action-link edit">Edit</a>
                                <form action="/admin/users/deactivate" method="POST" style="display:inline;">
                                    <input type="hidden" name="user_id" value="<%= manager.user_id %>">
                                    <button type="submit" class="action-link delete" style="background:none; border:none; cursor:pointer; padding:0;">Deactivate</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Tenants -->
            <div class="card">
                <div class="card-header">
                    <h3>Tenants</h3>
                    <span class="badge badge-green"><%= tenants.length %> Active</span>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Apartment</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tenants.forEach(function(tenant, index) { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= tenant.name %></td>
                            <td><%= tenant.email %></td>
                            <td><%= tenant.phone || '—' %></td>
                            <td><%= tenant.property_name %> — <%= tenant.apt_number %></td>
                            <td>
                                <span class="badge <%= tenant.is_active ? 'badge-green' : 'badge-orange' %>">
                                    <%= tenant.is_active ? 'Active' : 'Inactive' %>
                                </span>
                            </td>
                            <td>
                                <a href="#" class="action-link edit">Edit</a>
                                <form action="/admin/users/deactivate" method="POST" style="display:inline;">
                                    <input type="hidden" name="user_id" value="<%= tenant.user_id %>">
                                    <button type="submit" class="action-link delete" style="background:none; border:none; cursor:pointer; padding:0;">Deactivate</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal-overlay" id="addUserModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New User</h3>
            <button class="modal-close" onclick="document.getElementById('addUserModal').style.display='none'">✕</button>
        </div>
        <form action="/admin/users/add" method="POST">
            <div class="modal-body">
                <select class="form-control" name="role" id="roleSelect" onchange="togglePropertyField()" required>
                    <option value="">Select Role</option>
                    <option value="property_manager">Property Manager</option>
                </select>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="name" placeholder="Enter full name" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input type="text" class="form-control" name="phone" placeholder="10-digit number">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" placeholder="Enter email" required>
                </div>
                <div class="form-group" id="propertyField" style="display:none;">
                    <label class="form-label">Assign Property</label>
                    <select class="form-control" name="property_id">
                        <option value="">Select Property</option>
                        <% properties.forEach(function(property) { %>
                        <option value="<%= property.property_id %>"><%= property.name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Set Password</label>
                    <input type="password" class="form-control" name="password" placeholder="Set a password for this user" required>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="document.getElementById('addUserModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary-custom btn-inline">Create User</button>
            </div>
        </form>
    </div>
</div>

<script>
function togglePropertyField() {
    const role = document.getElementById('roleSelect').value;
    const field = document.getElementById('propertyField');
    field.style.display = role === 'property_manager' ? 'block' : 'none';
}
</script>

<%- include('../partials/auth-check') %>

</body>
</html>