<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RentEase — Properties</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-wrapper">
    <%- include('../partials/sidebar-admin') %>

    <div class="main-content">
        <div class="topbar">
            <div class="topbar-title">Properties</div>
            <div class="topbar-user"><%= user.name %></div>
        </div>

        <div class="page-content">

            <!-- Add Property Button -->
            <div class="page-actions">
                <button class="btn-primary-custom btn-inline" onclick="document.getElementById('addPropertyModal').style.display='flex'">
                    + Add Property
                </button>
            </div>

            <!-- Properties Table -->
            <div class="card">
                <div class="card-header">
                    <h3>All Properties</h3>
                    <span class="badge badge-green">12 Total</span>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Property Name</th>
                            <th>Address</th>
                            <th>Floors</th>
                            <th>Apartments</th>
                            <th>Manager</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% properties.forEach(function(property, index) { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= property.name %></td>
                            <td><%= property.city %>, <%= property.state %></td>
                            <td><%= property.total_floors %></td>
                            <td><%= property.total_apartments %></td>
                            <td><%= property.manager_name || 'Unassigned' %></td>
                            <td>
                                <a href="#" class="action-link edit">Edit</a>
                                <a href="#" class="action-link delete">Delete</a>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Add Property Modal -->
<div class="modal-overlay" id="addPropertyModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New Property</h3>
            <button class="modal-close" onclick="document.getElementById('addPropertyModal').style.display='none'">✕</button>
        </div>
        <form action="/admin/properties/add" method="POST">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Property Name</label>
                    <input type="text" class="form-control" name="name" placeholder="e.g. Sunrise Apartments" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Address</label>
                    <input type="text" class="form-control" name="address" placeholder="Street address" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" name="city" placeholder="e.g. Panaji" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">State</label>
                        <input type="text" class="form-control" name="state" placeholder="e.g. Goa" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Pincode</label>
                        <input type="text" class="form-control" name="pincode" placeholder="e.g. 403001" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Property Type</label>
                        <select class="form-control" name="property_type">
                            <option value="residential">Residential</option>
                            <option value="commercial">Commercial</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Total Floors</label>
                        <input type="number" class="form-control" name="total_floors" placeholder="e.g. 4" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Total Apartments</label>
                        <input type="number" class="form-control" name="total_apartments" placeholder="e.g. 12" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Assign Property Manager</label>
                    <select class="form-control" name="manager_id">
                        <option value="">Select Manager</option>
                        <% managers.forEach(function(manager) { %>
                        <option value="<%= manager.user_id %>"><%= manager.name %></option>
                        <% }); %>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="document.getElementById('addPropertyModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary-custom btn-inline">Save Property</button>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/auth-check') %>

</body>
</html>