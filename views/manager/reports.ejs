<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RentEase — Reports</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-wrapper">
    <%- include('../partials/sidebar-manager') %>

    <div class="main-content">
        <div class="topbar">
            <div class="topbar-title">Reports</div>
            <div class="topbar-user"><%= user.name %> — Property Manager</div>
        </div>

        <div class="page-content">

            <!-- Filter Bar -->
            <div class="card">
                <div class="modal-body">
                    <form action="/manager/reports" method="GET">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">From Date</label>
                                <input type="date" class="form-control" name="from_date" value="<%= fromDate %>">
                            </div>
                            <div class="form-group">
                                <label class="form-label">To Date</label>
                                <input type="date" class="form-control" name="to_date" value="<%= toDate %>">
                            </div>
                            <div class="form-group" style="display:flex; align-items:flex-end;">
                                <button type="submit" class="btn-primary-custom btn-inline">Generate Report</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Summary Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Expected</div>
                    <div class="stat-value">₹<%= Number(summary.total_expected || 0).toLocaleString('en-IN') %></div>
                    <div class="stat-sub"><%= fromDate %> to <%= toDate %></div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Collected</div>
                    <div class="stat-value" style="color:#27ae60;">₹<%= Number(summary.total_collected || 0).toLocaleString('en-IN') %></div>
                    <div class="stat-sub"><%= summary.total_expected > 0 ? Math.round((summary.total_collected / summary.total_expected) * 100) : 0 %>% collection rate</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value" style="color:#f39c12;">₹<%= Number((summary.total_expected || 0) - (summary.total_collected || 0)).toLocaleString('en-IN') %></div>
                    <div class="stat-sub">Not yet paid</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Overdue</div>
                    <div class="stat-value" style="color:#e74c3c;">₹0</div>
                    <div class="stat-sub">Past due date</div>
                </div>
            </div>

            <!-- Occupancy -->
            <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr);">
                <div class="stat-card">
                    <div class="stat-label">Total Apartments</div>
                    <div class="stat-value"><%= summary.total_apartments || 0 %></div>
                    <div class="stat-sub">Across your properties</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Occupied</div>
                    <div class="stat-value" style="color:#27ae60;"><%= summary.occupied || 0 %></div>
                    <div class="stat-sub"><%= summary.total_apartments > 0 ? Math.round((summary.occupied / summary.total_apartments) * 100) : 0 %>% occupancy rate</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Vacant</div>
                    <div class="stat-value" style="color:#7f8c8d;"><%= summary.vacant || 0 %></div>
                    <div class="stat-sub">Available for rent</div>
                </div>
            </div>

            <!-- Property Breakdown -->
            <div class="card">
                <div class="card-header">
                    <h3>Property Breakdown — <%= fromDate %> to <%= toDate %></h3>
                    <a href="/report/download?from_date=<%= fromDate %>&to_date=<%= toDate %>" class="btn-primary-custom btn-inline">Download PDF</a>
                </div>
                <div class="card-header">
                    <h3>Property Breakdown — <%= fromDate %> to <%= toDate %></h3>
                    <div style="display:flex; gap:10px;">
                        <a href="/report/download?from_date=<%= fromDate %>&to_date=<%= toDate %>" class="btn-primary-custom btn-inline">Download PDF</a>
                        <a href="/report/excel" class="btn-primary-custom btn-inline" style="background-color:#27ae60;">Download Excel</a>
                    </div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Property</th>
                            <th>Total Units</th>
                            <th>Occupied</th>
                            <th>Expected Rent</th>
                            <th>Collected</th>
                            <th>Pending</th>
                            <th>Overdue</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% breakdown.forEach(function(row) { %>
                        <tr>
                            <td><%= row.name %></td>
                            <td><%= row.total_units %></td>
                            <td><%= row.occupied %></td>
                            <td>₹<%= Number(row.expected_rent).toLocaleString('en-IN') %></td>
                            <td><span style="color:#27ae60; font-weight:600;">₹<%= Number(row.collected).toLocaleString('en-IN') %></span></td>
                            <td><span style="color:#f39c12; font-weight:600;">₹<%= Number(row.expected_rent - row.collected).toLocaleString('en-IN') %></span></td>
                            <td><span style="color:#e74c3c; font-weight:600;">₹0</span></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Tenant Payment Details -->
            <div class="card">
                <div class="card-header">
                    <h3>Tenant Payment Details — May 2026</h3>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tenant</th>
                            <th>Apartment</th>
                            <th>Rent Amount</th>
                            <th>Paid On</th>
                            <th>Method</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tenantPayments.forEach(function(row) { %>
                        <tr>
                            <td><%= row.name %></td>
                            <td><%= row.property_name %> — <%= row.apt_number %></td>
                            <td>₹<%= Number(row.rent_amount).toLocaleString('en-IN') %></td>
                            <td><%= row.payment_date ? new Date(row.payment_date).toLocaleDateString('en-IN') : '—' %></td>
                            <td><%= row.payment_method ? row.payment_method.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) : '—' %></td>
                            <td>
                                <span class="badge <%= row.status === 'Paid' ? 'badge-green' : 'badge-orange' %>">
                                    <%= row.status %>
                                </span>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<%- include('../partials/auth-check') %>

</body>
</html>