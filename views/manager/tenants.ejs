<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RentEase — Tenants</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-wrapper">
    <%- include('../partials/sidebar-manager') %>

    <div class="main-content">
        <div class="topbar">
            <div class="topbar-title">Tenants</div>
            <div class="topbar-user"><%= user.name %> — Property Manager</div>
        </div>

        <div class="page-content">

            <div class="page-actions">
                <button class="btn-primary-custom btn-inline" onclick="document.getElementById('addTenantModal').style.display='flex'">
                    + Add Tenant
                </button>
            </div>

            <!-- Tenants Table -->
            <div class="card">
                <div class="card-header">
                    <h3>All Tenants</h3>
                    <span class="badge badge-green"><%= tenants.length %></span>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Apartment</th>
                            <th>Lease Start</th>
                            <th>Lease End</th>
                            <th>Deposit</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tenants.forEach(function(tenant, index) { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= tenant.name %></td>
                            <td><%= tenant.email %></td>
                            <td><%= tenant.phone || '—' %></td>
                            <td><%= tenant.property_name %> — <%= tenant.apt_number %></td>
                            <td><%= new Date(tenant.lease_start).toLocaleDateString('en-IN') %></td>
                            <td><%= tenant.lease_end ? new Date(tenant.lease_end).toLocaleDateString('en-IN') : '—' %></td>
                            <td>₹<%= Number(tenant.deposit_amount).toLocaleString('en-IN') %></td>
                            <td>
                                <a href="#" class="action-link edit edit-tenant-btn"
                                    data-id="<%= tenant.tenant_id %>"
                                    data-name="<%= tenant.name %>"
                                    data-phone="<%= tenant.phone || '' %>"
                                    data-lease-start="<%= tenant.lease_start ? new Date(tenant.lease_start).toISOString().split('T')[0] : '' %>"
                                    data-lease-end="<%= tenant.lease_end ? new Date(tenant.lease_end).toISOString().split('T')[0] : '' %>"
                                    data-deposit="<%= tenant.deposit_amount %>"
                                    data-idproof="<%= tenant.id_proof %>">Edit</a>
                                <form action="/manager/tenants/remove" method="POST" style="display:inline;">
                                    <input type="hidden" name="tenant_id" value="<%= tenant.tenant_id %>">
                                    <button type="submit" class="action-link delete" style="background:none; border:none; cursor:pointer; padding:0;"
                                        onclick="return confirm('Remove this tenant? Apartment will be marked vacant.')">Remove</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Add Tenant Modal -->
<div class="modal-overlay" id="addTenantModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New Tenant</h3>
            <button class="modal-close" onclick="document.getElementById('addTenantModal').style.display='none'">✕</button>
        </div>
        <form action="/manager/tenants/add" method="POST">
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="name" placeholder="Enter full name" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input type="text" class="form-control" name="phone" placeholder="10-digit number">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" placeholder="Enter email" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Set Password</label>
                    <input type="password" class="form-control" name="password" placeholder="Set login password for tenant" required>
                </div>
                <div class="form-group">
                    <label class="form-label">ID Proof Number</label>
                    <input type="text" class="form-control" name="id_proof" placeholder="Aadhar or PAN number" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Assign Apartment</label>
                    <select class="form-control" name="apartment_id" required>
                        <option value="">Select Vacant Apartment</option>
                        <% vacantApts.forEach(function(apt) { %>
                        <option value="<%= apt.apartment_id %>"><%= apt.property_name %> — <%= apt.apt_number %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Lease Start Date</label>
                        <input type="date" class="form-control" name="lease_start" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Lease End Date</label>
                        <input type="date" class="form-control" name="lease_end" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Deposit Amount (₹)</label>
                    <input type="number" class="form-control" name="deposit_amount" placeholder="e.g. 24000" required>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="document.getElementById('addTenantModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary-custom btn-inline">Add Tenant</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Tenant Modal -->
<div class="modal-overlay" id="editTenantModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Edit Tenant</h3>
            <button class="modal-close" onclick="document.getElementById('editTenantModal').style.display='none'">✕</button>
        </div>
        <form action="/manager/tenants/edit" method="POST">
            <input type="hidden" name="tenant_id" id="edit_tenant_id">
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="name" id="edit_tenant_name" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input type="text" class="form-control" name="phone" id="edit_tenant_phone">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">ID Proof Number</label>
                    <input type="text" class="form-control" name="id_proof" id="edit_tenant_idproof">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Lease Start Date</label>
                        <input type="date" class="form-control" name="lease_start" id="edit_tenant_lease_start">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Lease End Date</label>
                        <input type="date" class="form-control" name="lease_end" id="edit_tenant_lease_end">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Deposit Amount (₹)</label>
                    <input type="number" class="form-control" name="deposit_amount" id="edit_tenant_deposit">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="document.getElementById('editTenantModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary-custom btn-inline">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.edit-tenant-btn').forEach(function(el) {
        el.addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById('edit_tenant_id').value = this.dataset.id;
            document.getElementById('edit_tenant_name').value = this.dataset.name;
            document.getElementById('edit_tenant_phone').value = this.dataset.phone;
            document.getElementById('edit_tenant_lease_start').value = this.dataset.leaseStart;
            document.getElementById('edit_tenant_lease_end').value = this.dataset.leaseEnd;
            document.getElementById('edit_tenant_deposit').value = this.dataset.deposit;
            document.getElementById('edit_tenant_idproof').value = this.dataset.idproof;
            document.getElementById('editTenantModal').style.display = 'flex';
        });
    });
});
</script>

<%- include('../partials/auth-check') %>

</body>
</html>