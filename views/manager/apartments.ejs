<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RentEase — Apartments</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-wrapper">
    <%- include('../partials/sidebar-manager') %>

    <div class="main-content">
        <div class="topbar">
            <div class="topbar-title">Apartments</div>
            <div class="topbar-user"><%= user.name %> — Property Manager</div>
        </div>

        <div class="page-content">

            <div class="page-actions">
                <button class="btn-primary-custom btn-inline" onclick="document.getElementById('addApartmentModal').style.display='flex'">
                    + Add Apartment
                </button>
            </div>

            <!-- Filter Bar -->
            <div class="card">
                <div class="modal-body">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Filter by Property</label>
                            <select class="form-control">
                                <option value="">All Properties</option>
                                <% properties.forEach(function(property) { %>
                                <option value="<%= property.property_id %>"><%= property.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Filter by Status</label>
                            <select class="form-control">
                                <option>All</option>
                                <option>Vacant</option>
                                <option>Occupied</option>
                            </select>
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button class="btn-primary-custom btn-inline">Apply Filter</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Apartments Table -->
            <div class="card">
                <div class="card-header">
                    <h3>All Apartments</h3>
                    <span class="badge badge-green">20 Total</span>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Apartment No</th>
                            <th>Property</th>
                            <th>Floor</th>
                            <th>Bedrooms</th>
                            <th>Rent Amount</th>
                            <th>Status</th>
                            <th>Tenant</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% apartments.forEach(function(apt, index) { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= apt.apt_number %></td>
                            <td><%= apt.property_name %></td>
                            <td><%= apt.floor %></td>
                            <td><%= apt.bedrooms %> BHK</td>
                            <td>₹<%= Number(apt.rent_amount).toLocaleString('en-IN') %></td>
                            <td>
                                <span class="badge <%= apt.status === 'occupied' ? 'badge-green' : 'badge-orange' %>">
                                    <%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %>
                                </span>
                            </td>
                            <td><%= apt.tenant_name || '—' %></td>
                            <td>
                                <a href="#" class="action-link edit">Edit</a>
                                <a href="#" class="action-link delete">Delete</a>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Add Apartment Modal -->
<div class="modal-overlay" id="addApartmentModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Add New Apartment</h3>
            <button class="modal-close" onclick="document.getElementById('addApartmentModal').style.display='none'">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Property</label>
                <select class="form-control" name="property_id">
                    <% properties.forEach(function(property) { %>
                    <option value="<%= property.property_id %>"><%= property.name %></option>
                    <% }); %>
                </select>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Apartment Number</label>
                    <input type="text" class="form-control" placeholder="e.g. A-301">
                </div>
                <div class="form-group">
                    <label class="form-label">Floor</label>
                    <input type="number" class="form-control" placeholder="e.g. 3">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Bedrooms</label>
                    <select class="form-control">
                        <option>1 BHK</option>
                        <option>2 BHK</option>
                        <option>3 BHK</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Rent Amount (₹)</label>
                    <input type="number" class="form-control" placeholder="e.g. 12000">
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="document.getElementById('addApartmentModal').style.display='none'">Cancel</button>
            <button class="btn-primary-custom btn-inline">Save Apartment</button>
        </div>
    </div>
</div>

<%- include('../partials/auth-check') %>

</body>
</html>